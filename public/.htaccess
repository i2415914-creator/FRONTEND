# React Router SPA fallback para Apache/cPanel
# Copiado tal cual a dist/ por Vite en build
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Sirve index.html para cualquier ruta que no sea un archivo/carpeta real
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
